{
  "AllowedHosts": "*",
  "Caching": {
    "ActorLifetime": "00:15:00"
  },
  "Cookies": {
    "RefreshToken": {
      "HttpOnly": true,
      "MaxAge": "7.00:00:00",
      "SameSite": "Strict",
      "Secure": true
    },
    "Session": {
      "SameSite": "Strict"
    }
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": [ "DELETE", "GET", "PATCH", "POST", "PUT" ],
    "AllowedHeaders": [ "Content-Type" ],
    "AllowCredentials": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MongoDB": {
    "DatabaseName": "Pokemon"
  },
  "OAuth": {
    "AccessToken": {
      "Lifetime": 300,
      "TokenType": "at+jwt"
    }
  },
  "Portal": {
    "Realm": "pokegame"
  }
}
