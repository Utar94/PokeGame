@using PokeGame.Application.Items.Models;

@model ItemModel
@{
  Layout = "_Layout";

  ViewBag.Title = Model?.Name ?? "Create item";
}

@if (Model == null)
{
  <item-edit></item-edit>
}
else
{
  <item-edit json="@(ModelSerializer.Serialize(Model))" status="@(Context.Request.Query["status"])"></item-edit>
}
